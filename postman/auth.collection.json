    {
      "name": "Tenant Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Response is JSON', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is expected', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const setCookieHeaders = pm.response.headers.all()",
              "  .filter((header) => header.key.toLowerCase() === 'set-cookie')",
              "  .map((header) => header.value)",
              "  .join('\\n');",
              "",
              "function captureCookie(cookieName, variableName) {",
              "  const match = setCookieHeaders.match(new RegExp(cookieName + '=([^;]+)'));",
              "  if (match) {",
              "    pm.environment.set(variableName, decodeURIComponent(match[1]));",
              "  }",
              "}",
              "captureCookie('access_token', 'token');",
              "captureCookie('access_token', 'user_token');",
              "captureCookie('refresh_token', 'refresh_token');",
              "let json = {};",
              "try {",
              "  json = pm.response.json();",
              "} catch (error) {}",
              "if (json.data && json.data.user) {",
              "  pm.environment.set('tenant_id', json.data.user.tenantId || pm.environment.get('tenant_id'));",
              "  pm.environment.set('user_id', json.data.user.id);",
              "  pm.environment.set('user_role', json.data.user.role);",
              "}"
            ]
          }
        }
      ],
