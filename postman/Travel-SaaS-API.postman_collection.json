{
  "info": {
    "_postman_id": "travel-saas-api-collection",
    "name": "Travel SaaS API",
    "description": "Travel SaaS API — run folder **0. Bootstrap Flow** in order.\n\n**Auth:** login sets HttpOnly cookies (`access_token`, `refresh_token`). Postman sends them automatically on `localhost:3000`. Frontend: `credentials: 'include'` + CORS.\n\n**Local Postman:** set `tenantSubdomain`; pre-request adds `x-tenant-subdomain`. Bearer header still works for scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiPrefix", "value": "/api/v1" },
    { "key": "tenantId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "packageId", "value": "" },
    { "key": "departureId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "tenantSubdomain", "value": "himalayan-tours" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const sub = pm.environment.get('tenantSubdomain') || pm.collectionVariables.get('tenantSubdomain');",
          "if (sub) {",
          "  pm.request.headers.upsert({ key: 'x-tenant-subdomain', value: sub });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Bootstrap Flow",
      "description": "Run 1→6 in order. Needs: Docker Postgres, npm run db:setup, npm run dev. Step 6 needs SQL seed (see docs/POSTMAN.md).",
      "item": [
        {
          "name": "1. Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "2. Create Tenant + Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.tenant?.id) {",
                  "  pm.environment.set('tenantId', res.data.tenant.id);",
                  "  pm.collectionVariables.set('tenantId', res.data.tenant.id);",
                  "}",
                  "if (res.success && res.data?.tenant?.slug) {",
                  "  pm.environment.set('tenantSubdomain', res.data.tenant.slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Himalayan Tours\",\n  \"slug\": \"{{tenantSubdomain}}\",\n  \"country\": \"NP\",\n  \"timezone\": \"Asia/Kathmandu\",\n  \"owner\": {\n    \"email\": \"{{ownerEmail}}\",\n    \"password\": \"{{ownerPassword}}\",\n    \"fullName\": \"Agency Owner\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/admin/tenants",
            "description": "Creates tenant DB + owner user. Email sent if SMTP configured."
          }
        },
        {
          "name": "3. Login Owner (sets cookies)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.user?.tenantId) {",
                  "  pm.environment.set('tenantId', res.data.user.tenantId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/login",
            "description": "Sets HttpOnly cookies. Uses x-tenant-subdomain from pre-request script."
          }
        },
        {
          "name": "4. Create Staff (uses login cookies)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@himalayan-tours.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Travel Agent\",\n  \"role\": \"agent\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/users"
          }
        },
        {
          "name": "5. Login Agent (optional)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@himalayan-tours.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/login"
          }
        },
        {
          "name": "6. Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageId\": \"{{packageId}}\",\n  \"departureId\": \"{{departureId}}\",\n  \"travelDate\": \"2026-09-15\",\n  \"paxCount\": 1,\n  \"travelers\": [{ \"customerId\": \"{{customerId}}\" }]\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/bookings",
            "description": "Requires seeded package, departure, and customer in tenant DB. Set packageId, departureId, customerId in environment."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "No auth. Returns `{ status: 'ok' }`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Tenants",
      "description": "Platform-level tenant (travel agency) management. Master database.",
      "item": [
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}{{apiPrefix}}/admin/tenants"
          },
          "response": []
        },
        {
          "name": "Get Tenant by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}{{apiPrefix}}/admin/tenants/{{tenantId}}"
          },
          "response": []
        },
        {
          "name": "Create Tenant + Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.tenant?.id) {",
                  "  pm.collectionVariables.set('tenantId', res.data.tenant.id);",
                  "  pm.environment.set('tenantId', res.data.tenant.id);",
                  "}",
                  "if (res.success && res.data?.tenant?.slug) {",
                  "  pm.environment.set('tenantSubdomain', res.data.tenant.slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Himalayan Tours\",\n  \"slug\": \"{{tenantSubdomain}}\",\n  \"country\": \"NP\",\n  \"timezone\": \"Asia/Kathmandu\",\n  \"owner\": {\n    \"email\": \"{{ownerEmail}}\",\n    \"password\": \"{{ownerPassword}}\",\n    \"fullName\": \"Agency Owner\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/admin/tenants",
            "description": "**Required:** name, slug, owner { email, password (min 8), fullName? }. Creates tenant DB + owner user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Superadmin",
      "description": "Platform owner auth. Master database.",
      "item": [
        {
          "name": "Register Superadmin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@platform.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Platform Admin\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/superadmin/register"
          },
          "response": []
        },
        {
          "name": "Login Superadmin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@platform.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/superadmin/login",
            "description": "Sets HttpOnly `superadmin_token` cookie. Returns `{ user }` only."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth (Agency Staff)",
      "description": "Tenant from x-tenant-subdomain header (auto). No public register.",
      "item": [
        {
          "name": "Create Staff (owner/admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@himalayan-tours.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Travel Agent\",\n  \"role\": \"agent\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/users"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.user?.tenantId) {",
                  "  pm.collectionVariables.set('tenantId', res.data.user.tenantId);",
                  "  pm.environment.set('tenantId', res.data.user.tenantId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@himalayan-tours.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/login",
            "description": "Sets HttpOnly cookies. Body: email + password. Tenant from x-tenant-subdomain."
          },
          "response": []
        },
        {
          "name": "Refresh tokens",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/refresh",
            "description": "Uses refresh_token cookie. Rotates session and sets new cookies."
          },
          "response": []
        },
        {
          "name": "Logout (revoke refresh)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/auth/logout",
            "description": "Clears auth cookies. Revokes refresh session when cookie present."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "description": "Tenant-scoped bookings. Requires login cookies (or Bearer) + tenant context.",
      "item": [
        {
          "name": "List Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }],
            "url": "{{baseUrl}}{{apiPrefix}}/bookings"
          },
          "response": []
        },
        {
          "name": "Get Booking by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.id) {",
                  "  pm.collectionVariables.set('bookingId', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-id", "value": "{{tenantId}}" }],
            "url": "{{baseUrl}}{{apiPrefix}}/bookings/{{bookingId}}"
          },
          "response": []
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.id) {",
                  "  pm.collectionVariables.set('bookingId', res.data.id);",
                  "  pm.environment.set('bookingId', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageId\": \"{{packageId}}\",\n  \"departureId\": \"{{departureId}}\",\n  \"travelDate\": \"2026-09-15\",\n  \"paxCount\": 1,\n  \"travelers\": [\n    { \"customerId\": \"{{customerId}}\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}{{apiPrefix}}/bookings",
            "description": "**Rules:**\n- Package must be `published`\n- Departure must have available seats\n- `travelers.length` must equal `paxCount`\n\n**Prerequisites:** Seed tenant DB with package, departure, customer (see README)."
          },
          "response": []
        }
      ]
    }
  ]
}
