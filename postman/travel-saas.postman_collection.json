    },
    {
      "name": "Subdomain URL Examples",
      "item": [
        {
          "name": "Login Using Actual Tenant URL",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": { "raw": "{{tenantBaseUrl}}{{apiPrefix}}/auth/login" }
          }
        },
        {
          "name": "Packages Using Forwarded Host",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "x-forwarded-host", "value": "{{tenantHost}}" }
            ],
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/packages/public?page=1&limit=20" }
          }
        }
      ]
    }
  ]
}
