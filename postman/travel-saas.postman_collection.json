    {
      "name": "Platform - Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const tenant = json.data && (json.data.tenant || json.data);",
                  "if (tenant && tenant.id) pm.environment.set('tenantId', tenant.id);",
                  "if (tenant && tenant.slug) pm.environment.set('tenantSlug', tenant.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{tenantName}}\",\n  \"slug\": \"{{tenantSlug}}\",\n  \"country\": \"NP\",\n  \"timezone\": \"Asia/Kathmandu\",\n  \"owner\": {\n    \"email\": \"{{ownerEmail}}\",\n    \"password\": \"{{ownerPassword}}\",\n    \"fullName\": \"Demo Owner\"\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/admin/tenants" }
          }
        },
        {
          "name": "List Tenants",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/admin/tenants" }
          }
        },
        {
          "name": "Get Tenant By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/admin/tenants/{{tenantId}}" }
          }
        }
      ]
    },
    {
      "name": "Superadmin",
      "item": [
        {
          "name": "Register Superadmin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadminEmail}}\",\n  \"password\": \"{{superadminPassword}}\",\n  \"fullName\": \"Platform Admin\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/superadmin/register" }
          }
        },
        {
          "name": "Login Superadmin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').map(h => h.value).join('; ');",
                  "const match = setCookies.match(/superadmin_token=([^;]+)/);",
                  "if (match) pm.environment.set('superadminToken', decodeURIComponent(match[1]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadminEmail}}\",\n  \"password\": \"{{superadminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/superadmin/login" }
          }
        }
      ]
    },
    {
      "name": "Auth - Agency Staff",
      "item": [
        {
          "name": "Get Agency Public Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/auth/agency/{{tenantSlug}}" }
          }
        },
        {
          "name": "Login By Tenant Subdomain Header",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').map(h => h.value).join('; ');",
                  "const access = setCookies.match(/access_token=([^;]+)/);",
                  "const refresh = setCookies.match(/refresh_token=([^;]+)/);",
                  "if (access) pm.environment.set('accessToken', decodeURIComponent(access[1]));",
                  "if (refresh) pm.environment.set('refreshToken', decodeURIComponent(refresh[1]));",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.user && json.data.user.tenantId) pm.environment.set('tenantId', json.data.user.tenantId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-subdomain", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/auth/login" }
          }
        },
        {
          "name": "Login By Forwarded Host",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').map(h => h.value).join('; ');",
                  "const access = setCookies.match(/access_token=([^;]+)/);",
                  "const refresh = setCookies.match(/refresh_token=([^;]+)/);",
                  "if (access) pm.environment.set('accessToken', decodeURIComponent(access[1]));",
                  "if (refresh) pm.environment.set('refreshToken', decodeURIComponent(refresh[1]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-forwarded-host", "value": "{{tenantHost}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/auth/login" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookies = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie').map(h => h.value).join('; ');",
                  "const access = setCookies.match(/access_token=([^;]+)/);",
                  "const refresh = setCookies.match(/refresh_token=([^;]+)/);",
                  "if (access) pm.environment.set('accessToken', decodeURIComponent(access[1]));",
                  "if (refresh) pm.environment.set('refreshToken', decodeURIComponent(refresh[1]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-subdomain", "value": "{{tenantSlug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}{{apiPrefix}}/auth/refresh" }
