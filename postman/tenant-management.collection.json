              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is expected', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 200]);",
              "});",
              "let json = {};",
              "try {",
              "  json = pm.response.json();",
              "} catch (error) {}",
              "if (json.data && json.data.tenant) {",
              "  pm.environment.set('tenant_id', json.data.tenant.id);",
              "  pm.environment.set('tenant_slug', json.data.tenant.slug);",
              "  pm.environment.set('tenant_subdomain', json.data.tenant.slug);",
              "}",
              "if (json.data && json.data.owner) {",
              "  pm.environment.set('owner_email', json.data.owner.email);",
              "}"
            ]
          }
        }
