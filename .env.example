NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

MASTER_DB_HOST=localhost
MASTER_DB_PORT=5432
MASTER_DB_USER=postgres
MASTER_DB_PASSWORD=postgres
MASTER_DB_NAME=travel_saas_master

TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=postgres

# Local Docker: leave defaults (auto-create DBs, no SSL)
# Render / cloud: set both below
# DB_AUTO_CREATE=false
# DB_SSL=true

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AES-256-GCM key material for refresh tokens at rest (min 16 chars; use 32+ random in production)
ENCRYPTION_KEY=change-me-32-char-secret-min-16!!

PLATFORM_ROOT_DOMAIN=localhost
PLATFORM_APP_PROTOCOL=http
PLATFORM_APP_PORT=5173

CORS_ORIGIN=http://localhost:5173

# Auth cookies (HttpOnly) — frontend must use credentials: 'include'
# Local SPA on :5173 → proxy /api to :3000 in Vite, or use SameSite=None + HTTPS
# COOKIE_SECURE=false
# COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=.localhost

# Email (SMTP) — optional; if MAIL_HOST is empty, sends are skipped (no error)
# MAIL_ENABLED=false
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM="Travel SaaS" <noreply@yourdomain.com>
