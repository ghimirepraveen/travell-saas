{
  "name": "travel-saas",
  "version": "1.0.0",
  "description": "Multi-tenant travel agency SaaS backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:master": "tsx scripts/migrate-master.ts",
    "migrate:tenant": "tsx scripts/migrate-tenant.ts",
    "migrate:all-tenants": "tsx scripts/migrate-all-tenants.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:setup": "tsx scripts/db-setup.ts",
    "generate:master": "drizzle-kit generate --config=drizzle.config.ts",
    "generate:tenant": "drizzle-kit generate --config=drizzle.tenant.config.ts"
  },
  "keywords": [
    "travel",
    "saas",
    "multi-tenant"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "uuid": "^11.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
